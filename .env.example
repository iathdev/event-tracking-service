# Server Configuration
APP_ENV=develop
APP_PORT=8080

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=event_tracking
DB_SSL_MODE=disable
DB_MAX_IDLE_CONNS=20
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=30
DB_CONN_MAX_IDLE_TIME=10

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Scheduler Configuration
SCHEDULER_PROCESS_INTERVAL_MINUTES=2
SCHEDULER_PROCESS_TIMEOUT_MINUTES=1

# Logger Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_SERVICE_NAME=event-tracking
LOG_CHANNEL=console
LOG_OTLP_ENDPOINT=localhost:4318
LOG_OTLP_TOKEN=
LOG_ENABLE_GRPC=false
LOG_ENABLE_ASYNC=false
LOG_ASYNC_BUFFER_SIZE=2048
LOG_BATCH_SIZE=100
LOG_BATCH_TIMEOUT=10

# Tracing Configuration (OpenTelemetry)
TRACING_ENABLE=false
TRACING_SERVICE_NAME=event-tracking
TRACING_ENDPOINT=localhost:4318
TRACING_USE_GRPC=false
TRACING_SAMPLE_RATIO=1.0

# Sentry Configuration
SENTRY_ENABLE=false
SENTRY_DSN=
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_DEBUG=false
